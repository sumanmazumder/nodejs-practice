<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">

</head>
<body>
    <%- include('../includes/navigation.ejs') %>
        <main>
            <form action="/admin/add-product" method="POST" class="product-form">
                <div class="form-control">
                    <label for="title">Title</label>
                    <input type="text" name="title" placeholder="Name" id="title" value="<% if (editing) { %> <%= product.title %> <% } %>"/>
                </div>

                <div class="form-control">
                    <label for="imgUrl">Image</label>
                    <input type="text" name="imgUrl" placeholder="upload image" id="imgUrl" value="<% if (editing) { %> <%= product.imgUrl %> <% } %>"/>
                </div>
                <div class="form-control">
                    <label for="price">Price</label>
                    <input type="text" name="price" placeholder="Enter price" id="price" value="<% if (editing) { %> <%= product.price %> <% } %>" />
                </div>
                <div class="form-control">
                    <label for="des">Description</label>
                    <textarea name="description" id="description" rows="5" value=""><% if (editing) { %> <%= product.description %> <% } %></textarea>
                </div>
                <% if(editing) { %> <button class="btn" type="submit">Update</button> <input type="hidden" value="<%= product.id %>" name="productId" /> <% } %>
                <% if(!editing) { %> <button class="btn" type="submit">Submit</button> <% } %>
                
            </form>
            
            </div>
        </main>
<%- include('../includes/end.ejs') %>