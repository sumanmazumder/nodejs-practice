<%- include('../includes/header.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">

    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
            <main>
                <form action="/admin/<% if (editing) { %>edit-product<% } else { %>add-product<% } %>" method="POST" class="product-form">
                    <div class="form-control">
                        <label>Title</label>
                        <input type="text" placeholder="title" name="title" value="<% if (editing) { %><%= product.title %><% } %>" />
                    </div>
                    <div class="form-control">
                        <label>Image</label>
                        <input type="text" placeholder="image url peast" name="imgUrl" value="<% if (editing) { %><%= product.imgUrl %><% } %>" />
                    </div>
                    <div class="form-control">
                        <label>Price</label>
                        <input type="number" step="0.01" placeholder="price" name="price" value="<% if (editing) { %><%= product.price %><% } %>" />
                    </div>
                    <div class="form-control">
                        <label>Description</label>
                        <textarea name="description"><% if (editing) { %><%= product.description %><% } %></textarea>
                    </div>
                    <% if(editing) { %> <button class="btn" type="submit">Update</button> <input type="hidden" value="<%= product.id %>" name="productId" /> <% } %>
                    <% if(!editing) { %> <button class="btn" type="submit">Submit</button> <% } %>
                </form>
            </main>
    </body>


    <%- include('../includes/end.ejs') %>